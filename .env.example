# ── Server ──────────────────────────────────────────────────────────────────
PORT=8191
PUBLIC_URL=https://your-railway-app.up.railway.app

# ── Database ─────────────────────────────────────────────────────────────────
# Railway injects DATABASE_URL automatically when you add the Postgres plugin.
# For Neon: get the pooled connection string from your Neon project dashboard.
DATABASE_URL=postgresql://user:password@host:5432/dbname
DB_ADAPTER=pg

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=https://your-vercel-app.vercel.app

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_MAX_CONTEXT_MESSAGES=40
# OPENAI_MAX_TOOL_ITERATIONS=8

# ── SunCulture AMT ───────────────────────────────────────────────────────────
AMT_BASE_URL=https://amt.sunculture.io/api
AMT_EMPLOYEE_ID=your-employee-id
AMT_API_KEY=your-amt-api-key
AMT_SALES_APP_REQUEST_URL=https://amt.sunculture.io/api/sales-app/request
AMT_LEAD_FORM_ID=19
AMT_LEAD_FORM_VERSION=175

# ── WebSocket (optional shared secret for non-JWT clients) ───────────────────
# CHAT_SOCKET_SECRET=

# ── VAPI (voice calls) ───────────────────────────────────────────────────────
VAPI_API_KEY=your-vapi-api-key

# ── Telegram ─────────────────────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_SECRET=
