# # Vapi API key — from https://dashboard.vapi.ai → Account → API Keys
# VAPI_API_KEY=your-vapi-api-key-here

# # Server port
# PORT=3000

# # Public URL from ngrok — update each dev session
# # e.g. https://xxxx.ngrok-free.app
# #PUBLIC_URL=https://xxxx.ngrok-free.app
# PUBLIC_URL=http://localhost:3000

# # Telegram
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
# TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret-here


# # SunCulture AMT API — customer account lookup, agent validation, lead creation
# AMT_BASE_URL=https://amt.sunculture.io/api
# AMT_EMPLOYEE_ID=your-employee-id
# AMT_API_KEY=your-amt-api-key
# # Optional: lead POST proxy (defaults to AMT test stack)
# # AMT_SALES_APP_REQUEST_URL=https://amt-test.sunculture.io/api/sales-app/request
# # AMT_LEAD_FORM_ID=19
# # AMT_LEAD_FORM_VERSION=175

# # OpenAI — native WebSocket chat (src/chat) — not used by Vapi
# #OPENAI_API_KEY=sk-your-openai-key
# OPENAI_API_KEY=sk-your-openai-key-here
# # Optional: model and limits (see docs/environment-variables.md)
# OPENAI_CHAT_MODEL=gpt-4o-mini
# # OPENAI_MAX_CONTEXT_MESSAGES=40
# # OPENAI_MAX_TOOL_ITERATIONS=8
# # If set, clients must pass the same value as socket.io `auth: { token }` (or query `token=`)
# # CHAT_SOCKET_SECRET=

# # Database — PostgreSQL connection
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_voice_agent
# # DB_ADAPTER: 'pg' for standard PostgreSQL, 'neon' for Neon serverless
# DB_ADAPTER=pg



